# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# .env.production holds ONLY public NEXT_PUBLIC_* vars (safe to commit —
# the Supabase anon key is designed to be exposed to browsers; RLS guards data).
# Secrets (SERVICE_ROLE_KEY, GEMINI_API_KEY) stay out of git as runtime secrets.
!.env.production

# editor/tooling local settings
.claude/
.vscode/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OpenNext
.open-next

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
